datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Deal {
  id              String   @id @default(cuid())
  name            String
  policyOwner     String   @default("")
  policyIssueDate String?
  status          String   @default("draft")
  totalDeposit    Float
  inputsJson      String
  resultsJson     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
